        <id>488948347</id>
        <title>【Chromium &amp;gt; UI】 From 335e63f3463714b5c49c330987c667fd1958d247 Mon Sep 17 00:00:00 2001 From: Andrew Grieve &amp;lt;agrieve@chromium.org&amp;gt; Date: Fri, 06 Feb 2026 10:51:42 -0800 Subject: [PATCH] Enable dwarf5 for target_os="android" is_official_build=false Some timings &amp; size metrics in linked bug. Tested that stack traces still work for failed CHECK()s. Bug: 479802735 Change-Id: If638c89e5fe42ec743b464a1f47ac0adcefde95b Reviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/7533136 Reviewed-by: Nico Weber &amp;lt;thakis@chromium.org&amp;gt; Auto-Submit: Andrew Grieve &amp;lt;agrieve@chromium.org&amp;gt; Commit-Queue: Andrew Grieve &amp;lt;agrieve@chromium.org&amp;gt; Cr-Commit-Position: refs/heads/main@{#1580982} --- diff --git a/build/config/compiler/BUILD.gn b/build/config/compiler/BUILD.gn index 11c361d0..3caedeb 100644 --- a/build/config/compiler/BUILD.gn +++ b/build/config/compiler/BUILD.gn @@ -161,7 +161,8 @@ use_text_section_splitting = is_chromeos # Enable DWARF v5. - use_dwarf5 = false + # See analysis for is_android at https://crbug.com/479802735 + use_dwarf5 = is_android &amp;&amp; !is_official_build # Untested on official builds. # Override this to put full paths to PDBs in Windows PE files. This helps # windbg and Windows Performance Analyzer with finding the PDBs in some local- @@ -3156,16 +3157,26 @@ asmflags = cflags ldflags = [] - _enable_gdb_index = symbol_level == 2 &amp;&amp; !is_apple &amp;&amp; use_lld &amp;&amp; !is_wasm - if (_enable_gdb_index) { - if (is_clang) { - # This flag enables the GNU-format pubnames and pubtypes sections, - # which lld needs in order to generate a correct GDB index. - # TODO(pcc): Try to make lld understand non-GNU-format pubnames - # sections (llvm.org/PR34820). - cflags += [ "-ggnu-pubnames" ] + # Disable debugger index for Android, which uses lldb. lldb can create (and + # cache) its own index in about 20 seconds, so there's no need to pay the + # price of an index on every link. + _add_symbol_index = + symbol_level == 2 &amp;&amp; !is_apple &amp;&amp; use_lld &amp;&amp; !is_wasm &amp;&amp; !is_android + if (_add_symbol_index) { + if (use_dwarf5) { + cflags += [ "-gpubnames" ] + } else { + if (is_clang) { + # This flag enables the GNU-format pubnames and pubtypes sections, + # which lld needs in order to generate a correct GDB index. + # TODO(pcc): Try to make lld understand non-GNU-format pubnames + # sections (llvm.org/PR34820). + cflags += [ "-ggnu-pubnames" ] + } + ldflags += [ "-Wl,--gdb-index" ] } - ldflags += [ "-Wl,--gdb-index" ] + } else { + cflags += [ "-gno-pubnames" ] } }</title>
